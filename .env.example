# Server
ORK__SERVER__HOST=0.0.0.0
ORK__SERVER__PORT=8080

# Database
ORK__DATABASE__URL=postgres://ork:ork@localhost:5432/ork
ORK__DATABASE__MAX_CONNECTIONS=10

# Redis
ORK__REDIS__URL=redis://127.0.0.1/

# Auth
ORK__AUTH__JWT_SECRET=replace-with-a-strong-secret
ORK__AUTH__TOKEN_EXPIRY_HOURS=24

# LLM (ADR 0012). The provider catalog lives in `[llm]` / `[[llm.providers]]`
# in TOML — there is no flat `ORK__LLM__PROVIDER`/`BASE_URL`/`MODEL` env-var
# shape any more. Header values can be `{ env = "VAR_NAME" }`, in which case
# the named env var is read at boot (and the binary refuses to start if it's
# unset). Whatever the env var contains is sent **verbatim** as the header
# value — there is no per-provider prefix munging. So for the demo's minimax
# provider, which references `MINIMAX_API_KEY` as its `Authorization`
# header, you must include the `Bearer ` prefix in the env var itself
# (this is a deliberate change from the pre-ADR-0012 `MinimaxProvider`,
# which used to wrap a bare key in `Bearer …` in code).
# See `docs/adrs/0012-multi-llm-providers.md` for the catalog shape and
# `demo/config/default.toml` for a working example.
MINIMAX_API_KEY=Bearer your-minimax-api-key

# Integrations
GITHUB_TOKEN=your-github-personal-access-token
# For GitHub Enterprise, set the API base URL (omit for github.com):
# GITHUB_BASE_URL=https://github.example.com/api/v3
GITLAB_TOKEN=your-gitlab-personal-access-token
GITLAB_BASE_URL=https://gitlab.com

# Kafka / async transport (ADR-0004). Leave brokers unset to use the in-memory backend.
# ORK__KAFKA__BROKERS=broker1:9092,broker2:9092
# ORK__KAFKA__NAMESPACE=ork.a2a.v1
# ORK__KAFKA__SECURITY_PROTOCOL=SASL_SSL
# ORK__KAFKA__SASL_MECHANISM=OAUTHBEARER

# Gateway webhooks (ADR-0013). Reference from `[[gateways]]` `secret_env` when using the
# built-in `webhook` adapter with HMAC verification.
# ORK_GATEWAY_WEBHOOK_SECRET=change-me

# Remote A2A agent secrets (ADR-0007). Each `[[remote_agents]]` toml entry names
# the env var holding its credentials via the `*_env` fields. Example for an
# OAuth2 client_credentials vendor:
# VENDOR_CLIENT_ID=replace-with-vendor-client-id
# VENDOR_CLIENT_SECRET=replace-with-vendor-client-secret
# Static-bearer vendor:
# OTHER_BEARER=replace-with-static-bearer-token
# Static API key vendor:
# OTHER_API_KEY=replace-with-api-key

# A2A discovery (ADR-0005). Defaults: interval = 30s, ttl = 3 * interval.
# ORK__DISCOVERY__INTERVAL_SECS=30
# ORK__DISCOVERY__TTL_MULTIPLIER=3
# Public Kong base URL — used to build per-agent card URLs.
# ORK__DISCOVERY__PUBLIC_BASE_URL=https://api.example.com/
# Agent id served by GET /.well-known/agent-card.json (the bare default endpoint).
# ORK__DISCOVERY__DEFAULT_AGENT_ID=planner
# ORK__DISCOVERY__PROVIDER_ORGANIZATION=Example Corp
# ORK__DISCOVERY__DEVPORTAL_URL=https://devportal.example.com/
# ORK__DISCOVERY__INCLUDE_TENANT_REQUIRED_EXT=false
