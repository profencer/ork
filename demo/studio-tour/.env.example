# Pick one LLM key (the demo tries them in this order):
#   1. ORK_DEMO_LLM_API_KEY  — demo-specific override
#   2. OPENAI_API_KEY        — standard OpenAI / OpenRouter
#   3. MINIMAX_API_KEY       — matches the existing kitchen-sink demo
#
# Pass the literal Authorization header value. A bare key gets
# auto-prefixed with `Bearer `; if your provider expects a different
# prefix, supply the whole header yourself (e.g. `Bearer sk-...`).
#
# Optional overrides:
#   ORK_DEMO_LLM_BASE_URL  — defaults to https://api.openai.com/v1
#   ORK_DEMO_LLM_MODEL     — defaults to gpt-4o-mini
#   ORK_DEMO_DB_PATH       — libsql memory file (defaults to ./demo-studio-tour.db)

# OPENAI_API_KEY=sk-...
# ORK_DEMO_LLM_BASE_URL=https://api.openai.com/v1
# ORK_DEMO_LLM_MODEL=gpt-4o-mini

# Minimax-flavoured (the kitchen-sink demo's default):
# MINIMAX_API_KEY="Bearer sk-..."
# ORK_DEMO_LLM_BASE_URL=https://api.minimax.chat/v1
# ORK_DEMO_LLM_MODEL=MiniMax-Text-01

# Optional: rust-trace filter (see crates/ork-app for spans of interest)
# RUST_LOG=info,ork_studio=debug,demo_studio_tour=debug
